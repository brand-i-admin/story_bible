{
  "_doc": {
    "purpose": "지도 위에 양피지 톤 일러스트로 깔리는 데코(decoration) 카탈로그. 시대마다 어디에 어떤 일러스트가 떠야 하는지 정의. 사건과 무관한 분위기용 시각 요소.",
    "rules": {
      "kind": "데코 종류 — 'mountain' | 'mountain_range' | 'tree_oak' | 'palm' | 'tree_cluster' | 'city_walled' | 'city_ruins' | 'pyramid' | 'temple' | 'wilderness_dunes' | 'wilderness_rock' | 'olive_tree' | 'vineyard' | 'shepherd_tent' | 'ship' | 'oasis' (battle_swords 폐기 — landmark 성격)",
      "asset": "PNG 파일명. tools/images/generate_decos_vertex.py 가 assets/decos/{kind}.png 로 저장 (kind당 1장).",
      "lat_lng": "지도 위 표시 위치 (decorative — 정확한 위치보다 분위기). 보통 region 폴리곤 안 빈 공간을 채워 시각 풍성하게.",
      "era_codes": "이 데코가 보이는 시대들. 비어있으면 모든 시대.",
      "scale": "기본 1.0. 0.7~1.3 범위로 강조/축소.",
      "rotation_deg": "0이 기본. 산처럼 회전하면 부자연스러운 데코는 0 유지."
    },
    "render_rule": "지도 z=5~9 사이에서 적절히 보이고, 줌아웃 시 자동 축소 (Marker px 단위)."
  },
