# 로컬 운영도구용 비밀 값 — 앱 번들에 포함하지 않는다.
# 사용법: cp .env.ops.example .env.ops 후 실제 값 채우기
# 주의: .env.ops 는 .gitignore 대상이다. 절대 커밋하지 않는다.

# Supabase Storage 업로드/정리 스크립트용 service_role 키.
# Dashboard > Project Settings > API Keys > service_role 에서 복사.
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# psql 연결용 — `make db-init` / `make apply-seeds` 실행 시 필요.
# Supabase Dashboard > Project Settings > Database > Connection string > URI 복사.
# direct host(db.<ref>.supabase.co)가 DNS에서 안 잡히면 session pooler 5432를 사용한다.
# 예: postgresql://postgres.<ref>:<password>@aws-...pooler.supabase.com:5432/postgres?sslmode=require
# transaction pooler 6543은 큰 seed 적용에 비권장.
SUPABASE_DB_URL_DEV=postgresql://postgres.<ref>:<password>@aws-0-...pooler.supabase.com:5432/postgres?sslmode=require
SUPABASE_DB_URL_PROD=
