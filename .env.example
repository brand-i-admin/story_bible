# Supabase 환경 키 — 실제 값은 Supabase Dashboard > Settings > API 에서 복사
# 사용법: cp .env.example .env 후 아래 값 채우기
# 주의: .env 자체는 .gitignore 대상 — 절대 커밋 금지

# 개발 환경
SUPABASE_URL_DEV=https://<your-dev-project>.supabase.co
SUPABASE_ANON_KEY_DEV=<your-dev-anon-key>

# 운영 환경 (flutter run --dart-define=ENV=prod 시 사용)
SUPABASE_URL_PROD=
SUPABASE_ANON_KEY_PROD=

# Vertex AI 에셋 파이프라인용 (tools/*.py 실행 시만 필요)
GOOGLE_CLOUD_PROJECT=

# Supabase Storage 업로드(관리자 전용 스크립트)용 service_role 키
# Dashboard > Settings > API > service_role 에서 복사. **절대 클라이언트에 노출 금지**
# Edge Function 도 Supabase 가 자동으로 SUPABASE_SERVICE_ROLE_KEY secret 을 주입한다.
SUPABASE_SERVICE_ROLE_KEY_DEV=
SUPABASE_SERVICE_ROLE_KEY_PROD=

# psql 직접 연결용 — `make apply-seeds` / `make apply-db-init` 실행 시 필요.
# Supabase Dashboard > Project Settings > Database > Connection string > URI 복사.
# 큰 INSERT 안정성을 위해 direct 5432 포트 권장 (pooler 6543 비권장).
SUPABASE_DB_URL_DEV=postgresql://postgres.<ref>:<password>@aws-0-...supabase.com:5432/postgres
SUPABASE_DB_URL_PROD=

# FCM 웹 푸시 VAPID 키 (Flutter Web 전용).
# Firebase Console > 프로젝트 설정 > Cloud Messaging > "웹 구성" > 키 쌍 생성.
# scripts/common.sh 가 .env 를 읽어 `--dart-define=FCM_VAPID_KEY=...` 로 자동 주입.
# 비어 있으면 웹 푸시가 비활성화 (인앱 알림은 정상 동작).
FCM_VAPID_KEY=
