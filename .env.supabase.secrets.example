# Supabase Edge Function secret template.
# Usage: cp .env.supabase.secrets.example .env.supabase.secrets
# Then fill real values and run: supabase secrets set --env-file .env.supabase.secrets
#
# .env.supabase.secrets is ignored by git. Do not commit real service account JSON.

# Vertex AI image generation Edge Functions
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
GCP_SERVICE_ACCOUNT_JSON=

# FCM send-push Edge Function
FIREBASE_SERVICE_ACCOUNT=
